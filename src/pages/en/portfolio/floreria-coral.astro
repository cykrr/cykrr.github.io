---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import background from "@/assets/background.svg";
import Layout from "@/layouts/Layout.astro";
import NavBar from "@/components/NavBar.astro";
import floreriaPreview from "@/assets/previews/floreria-coral.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const developers = [
    "Oscar Rojas Gaete",
];

const resources = {
    site: "https://www.floreriacoral.cl",
};
---

<Layout>
    <div class="fixed inset-0 -z-10 h-full w-full overflow-hidden">
        <img 
            src={background.src} 
            alt="" 
            fetchpriority="high" 
            class="h-full w-full object-cover blur-3xl opacity-20 scale-110" 
        />
        <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/50 to-zinc-950/90"></div>
    </div>

    <main class="flex flex-col justify-center py-16 sm:py-24">
        <div class="mb-12">
            <h1 class="text-4xl font-extrabold tracking-tight text-zinc-100 sm:text-6xl text-balance mb-4">
                {t('floreria.title')}
            </h1>
            <p class="text-lg text-zinc-300 font-medium">
                <strong>{t('floreria.role')}</strong> | <span class="text-gray-500 italic">{t('floreria.team_status')}</span>
            </p>
            <div class="flex gap-2 mt-4">
                {["E-commerce", "Local Business", "Cloudflare", "Modern Web"].map(tag => (
                    <span class="px-3 py-1 bg-zinc-800 text-zinc-300 rounded-full text-sm font-semibold">{t(`floreria.tags.${tag.toLowerCase().replace(/ /g, '_')}`)}</span>
                ))}
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
            <div class="lg:col-span-2 space-y-12 leading-relaxed text-zinc-300 text-pretty">
                <section>
                    <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('floreria.overview.title')}</h2>
                    <p>
                        {t('floreria.overview.p1')}
                    </p>
                    <p class="mt-4">
                        {t('floreria.overview.p2')}
                    </p>
                </section>

                <section>
                    <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('floreria.features.title')}</h2>
                    <h3 class="text-lg font-semibold text-zinc-100 mb-2">{t('floreria.features.1.title')}</h3>
                    <p>{t('floreria.features.1.description')}</p>

                    <h3 class="text-lg font-semibold text-zinc-100 mb-2">{t('floreria.features.2.title')}</h3>
                    <p>{t('floreria.features.2.description')}</p>

                    <h3 class="text-lg font-semibold text-zinc-100 mb-2">{t('floreria.features.3.title')}</h3>
                    <p>{t('floreria.features.3.description')}</p>
                </section>

                <section>
                    <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('floreria.challenge.title')}</h2>
                    <p>{t('floreria.challenge.p1')}</p>
                </section>

                <section>
                    <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('floreria.takeaways.title')}</h2>
                    <p>{t('floreria.takeaways.p1')}</p>
                </section>
            </div>

            <aside class="space-y-8 sticky top-24">
                <div class="bg-zinc-900/50 backdrop-blur-sm p-6 rounded-2xl border border-white/20 shadow-xl shadow-orange-900/5">
                    <img
                        src={floreriaPreview.src}
                        alt={t('floreria.aside.img_alt')}
                        class="w-full rounded-xl shadow-md mb-6"
                    />
                    <div class="flex flex-col gap-4">
                        <a
                            href={resources.site}
                            class="inline-flex items-center justify-center rounded-xl bg-orange-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-orange-600/20 transition-all hover:bg-orange-700 hover:-translate-y-0.5"
                        >
                            {t('floreria.aside.button')}
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="ml-2 h-4 w-4">
                                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                            </svg>
                        </a>
                    </div>
                </div>

                <div class="border-l-4 border-orange-200 pl-4 py-2">
                    <h3 class="font-semibold text-zinc-100 mb-2">{t('floreria.aside.developed_by')}</h3>
                    <ul class="space-y-1">
                        {developers.map((dev) => (
                            <li class="text-zinc-300 text-sm">{dev}</li>
                        ))}
                    </ul>
                </div>

                <div class="pt-8 border-t border-gray-200/60">
                    <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">
                        {t('floreria.aside.tech_stack_title')}
                    </h2>
                    <div class="mt-6 flex flex-wrap items-center gap-8">
                        <div class="group relative h-10 w-auto text-[#f38020] grayscale transition-all hover:grayscale-0">
                            <svg class="h-full w-auto" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 174 68">
                                <defs>
                                    <linearGradient id="cloudflare-pages-logo-gradient" x1="118.18%" x2="10.8%" y1="-2.39%" y2="101.62%">
                                        <stop offset="0%" stop-color="#fbb743"></stop>
                                        <stop offset="100%" stop-color="#f28333"></stop>
                                        <stop offset="100%" stop-color="#ea6b00"></stop>
                                    </linearGradient>
                                </defs>
                                <path fill="currentColor" d="M75.94 54V30h9.47c5.44 0 8.6 3.36 8.6 8.13 0 4.8-3.21 8.09-8.73 8.09H81V54h-5.07zM81 42.15h3.45c2.9 0 4.32-1.64 4.32-4.02 0-2.39-1.42-3.98-4.35-3.98h-3.42v8zm19.48 12.19c-3.43 0-5.98-1.8-5.98-5.37 0-4.02 3.2-5.21 6.77-5.54 3.12-.3 4.35-.46 4.35-1.62v-.07c0-1.47-.97-2.33-2.67-2.33-1.79 0-2.86.88-3.2 2.07l-4.61-.37c.69-3.28 3.52-5.34 7.84-5.34 4 0 7.64 1.8 7.64 6.09V54h-4.74v-2.5h-.14c-.88 1.68-2.6 2.84-5.26 2.84zm1.43-3.45c2.2 0 3.75-1.44 3.75-3.32v-1.91c-.6.4-2.38.65-3.47.8-1.76.25-2.92.94-2.92 2.35 0 1.37 1.1 2.08 2.64 2.08zm19.32 10.23c-4.86 0-7.63-2.17-8.23-5.01l4.62-.62c.4 1.09 1.52 2.05 3.72 2.05 2.17 0 3.75-.96 3.75-3.43v-3.3h-.2c-.66 1.5-2.27 2.93-5.14 2.93-4.06 0-7.3-2.79-7.3-8.78 0-6.12 3.34-9.2 7.29-9.2 3 0 4.47 1.8 5.14 3.26h.19V36h4.96v18.18c0 4.6-3.66 6.94-8.8 6.94zm.1-11.13c2.4 0 3.79-1.87 3.79-5.05 0-3.15-1.36-5.2-3.79-5.2-2.47 0-3.78 2.14-3.78 5.2 0 3.1 1.33 5.05 3.78 5.05zm19.5 4.36c-5.54 0-8.93-3.56-8.93-9.27 0-5.55 3.44-9.31 8.73-9.31 4.76 0 8.46 3.02 8.46 9.14v1.37h-12.25c0 2.7 1.58 4.35 4.08 4.35 1.66 0 2.95-.72 3.45-2.1l4.62.31c-.7 3.34-3.7 5.51-8.16 5.51zm-4-11.17h7.57a3.55 3.55 0 00-3.68-3.69 3.8 3.8 0 00-3.88 3.7zm29.12-2.05l-4.57.28c-.25-1.16-1.28-2.1-3.01-2.1-1.55 0-2.77.7-2.76 1.78 0 .86.61 1.44 2.29 1.8l3.26.66c3.49.71 5.19 2.27 5.2 4.87-.01 3.55-3.35 5.93-8.02 5.93-4.77 0-7.7-2.12-8.16-5.56l4.9-.26c.31 1.46 1.5 2.22 3.28 2.22 1.74 0 2.9-.76 2.92-1.82-.02-.9-.73-1.48-2.3-1.8l-3.12-.62c-3.52-.7-5.22-2.45-5.2-5.14-.02-3.47 3.02-5.6 7.62-5.6 4.55 0 7.22 2.05 7.67 5.36z"></path><path fill="currentColor" fill-opacity=".6" d="M84.14 17.86h-2.02c-.15-1.04-.94-1.68-2.03-1.68-1.47 0-2.43 1.13-2.43 3.1 0 2.01.98 3.08 2.41 3.08 1.07 0 1.86-.58 2.05-1.6l2.02.02c-.21 1.74-1.68 3.35-4.1 3.35-2.53 0-4.4-1.77-4.4-4.86 0-3.09 1.9-4.85 4.4-4.85 2.19 0 3.84 1.25 4.1 3.44zm2.83-3.31V24H85v-9.45h1.97zm4.23 9.59c-2.16 0-3.5-1.47-3.5-3.66 0-2.2 1.34-3.66 3.5-3.66 2.15 0 3.49 1.46 3.49 3.66 0 2.19-1.34 3.66-3.49 3.66z"></path>
                            </svg>
                            <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-zinc-400 opacity-0 group-hover:opacity-100 transition-opacity">
                                {t('floreria.aside.tech_cloudflare_pages')}
                            </span>
                        </div>
                        <div class="group relative">
                             <img 
                                src="https://assets.streamlinehq.com/image/private/w_300,h_300,ar_1/f_auto/v1/icons/1/cloudflare-workers-icon-jsii6pml8tdp4sy8kgarwe.png/cloudflare-workers-icon-gfyr5fw7aqcwsa1on45oem.png?_a=DATAg1AAZAA0" 
                                alt={t('floreria.aside.tech_cloudflare_workers')} 
                                class="h-12 w-auto object-contain grayscale transition-all hover:grayscale-0" 
                            />
                            <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-zinc-400 opacity-0 group-hover:opacity-100 transition-opacity">
                                {t('floreria.aside.tech_cloudflare_workers')}
                        </div>
                    </div>
                </div>
            </aside>
        </div>

        <section class="mt-16 pt-8 border-t border-white/10">
            <h2 class="text-2xl font-bold text-zinc-100 mb-6">{t('floreria.resources.title')}</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <a href={resources.site} target="_blank" class="group p-6 bg-zinc-900/40 backdrop-blur-sm border border-white/10 rounded-2xl hover:border-orange-400 hover:bg-zinc-800 transition-all">
                    <div class="text-orange-400 mb-4 group-hover:scale-110 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-zinc-100 text-lg">{t('floreria.resources.site.title')}</h3>
                    <p class="text-sm text-zinc-400 mt-2">{t('floreria.resources.site.description')}</p>
                </a>
            </div>
        </section>
    </main>
</Layout>
