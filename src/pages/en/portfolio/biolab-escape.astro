---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import background from "@/assets/background.svg";
import Layout from "@/layouts/Layout.astro";
import NavBar from "@/components/NavBar.astro";
import logoCsharp from "@/assets/badges/logo-csharp.png";
import logoUnity from "@/assets/badges/logo-unity.png";
import logoGhPages from "@/assets/badges/logo-gh-pages.png";

import biolabEscapeScreenshot from "@/assets/previews/biolab-escape.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const techStack = [
    {
        name: "Unity",
        src: logoUnity.src,
        class: "h-16",
    },
    {
        name: "C#",
        src: logoCsharp.src,
        class: "h-16",
    },
    {
        name: "GitHub Pages",
        src: logoGhPages.src,
        class: "h-16",
    },
];

const developers = [
    "Oscar Rojas Gaete",
    "Sebastián Jeria López",
    "Benjamín Robles",
    "Makarena Abarca Letelier",
    "Veronica Rojas Duran",
    "Silvana Roncagliolo de la Horra",
];
---

<Layout>

        <main class="flex flex-col justify-center py-16 sm:py-24">
            <div class="mb-12">
                <h1 class="text-4xl font-extrabold tracking-tight text-zinc-100 sm:text-6xl text-balance mb-4">
                    {t('biolab.title')}
                </h1>
                <p class="text-lg text-zinc-300 font-medium">
                    {t('biolab.role')} | <span class="text-gray-500 italic">{t('biolab.team_prefix')} Rojas Oscar, Jeria Sebastián, Robles Benjamín</span>
                </p>
                <div class="flex gap-2 mt-4">
                    {["EdTech", "Serious Games", "Game Design", "UX Research", "Gamification"].map(tag => (
                        <span class="px-3 py-1 bg-zinc-800 text-zinc-300 rounded-full text-sm font-semibold">{t(`biolab.tags.${tag.toLowerCase().replace(/ /g, '_')}`)}</span>
                    ))}
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
                <div class="lg:col-span-2 space-y-12 leading-relaxed text-zinc-300 text-pretty">
                    
                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.overview.title')}</h2>
                        <p set:html={t('biolab.overview.p1')}>
                        </p>
                        <p class="mt-4" set:html={t('biolab.overview.p2')}>
                        </p>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.challenge.title')}</h2>
                        <p set:html={t('biolab.challenge.p1')}>
                        </p>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.solution.title')}</h2>
                        <p set:html={t('biolab.solution.p1')}></p>
                        <ul class="list-disc ml-6 mt-4 space-y-2">
                            <li><strong>{t('biolab.solution.list.1.title')}</strong> <span set:html={t('biolab.solution.list.1.description')}></span></li>
                            <li><strong>{t('biolab.solution.list.2.title')}</strong> <span set:html={t('biolab.solution.list.2.description')}></span></li>
                            <li><strong>{t('biolab.solution.list.3.title')}</strong> <span set:html={t('biolab.solution.list.3.description')}></span></li>
                            <li><strong>{t('biolab.solution.list.4.title')}</strong> <span set:html={t('biolab.solution.list.4.description')}></span></li>
                        </ul>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.deep_dive.title')}</h2>
                        <p set:html={t('biolab.deep_dive.p1')}></p>
                        <ol class="list-decimal ml-6 mt-4 space-y-4">
                            <li><strong>{t('biolab.deep_dive.list.1.title')}</strong> <span set:html={t('biolab.deep_dive.list.1.description')}></span></li>
                            <li><strong>{t('biolab.deep_dive.list.2.title')}</strong> <span set:html={t('biolab.deep_dive.list.2.description')}></span></li>
                            <li><strong>{t('biolab.deep_dive.list.3.title')}</strong> <span set:html={t('biolab.deep_dive.list.3.description')}></span></li>
                        </ol>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.ux_research.title')}</h2>
                        <p set:html={t('biolab.ux_research.p1')}></p>
                        <ul class="list-disc ml-6 mt-4 space-y-2">
                            <li><strong>{t('biolab.ux_research.list.1.title')}</strong> <span set:html={t('biolab.ux_research.list.1.description')}></span></li>
                            <li><strong>{t('biolab.ux_research.list.2.title')}</strong> <span set:html={t('biolab.ux_research.list.2.description')}></span></li>
                        </ul>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.key_results.title')}</h2>
                        <p set:html={t('biolab.key_results.p1')}></p>
                        <ul class="list-disc ml-6 mt-4 space-y-2">
                            <li><strong>{t('biolab.key_results.list.1.title')}</strong> <span set:html={t('biolab.key_results.list.1.description')}></span></li>
                            <li><strong>{t('biolab.key_results.list.2.title')}</strong> 
                                <ul class="list-circle ml-6 mt-2">
                                    <li><em set:html={t('biolab.key_results.list.2.sublist.1.title')}></em> <span set:html={t('biolab.key_results.list.2.sublist.1.description')}></span></li>
                                    <li><em set:html={t('biolab.key_results.list.2.sublist.2.title')}></em> <span set:html={t('biolab.key_results.list.2.sublist.2.description')}></span></li>
                                </ul>
                            </li>
                            <li><strong>{t('biolab.key_results.list.3.title')}</strong> <span set:html={t('biolab.key_results.list.3.description')}></span></li>
                        </ul>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.challenges.title')}</h2>
                        <div class="space-y-4">
                            <p><strong>{t('biolab.challenges.p1.title')}</strong> <span set:html={t('biolab.challenges.p1.description')}></span></p>
                            <p><strong>{t('biolab.challenges.p2.title')}</strong> <span set:html={t('biolab.challenges.p2.description')}></span></p>
                            <p><strong>{t('biolab.challenges.p3.title')}</strong> <span set:html={t('biolab.challenges.p3.description')}></span></p>
                        </div>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('biolab.future_iterations.title')}</h2>
                        <ul class="list-disc ml-6 mt-2 space-y-2">
                            <li><strong>{t('biolab.future_iterations.list.1.title')}</strong> <span set:html={t('biolab.future_iterations.list.1.description')}></span></li>
                            <li><strong>{t('biolab.future_iterations.list.2.title')}</strong> <span set:html={t('biolab.future_iterations.list.2.description')}></span></li>
                            <li><strong>{t('biolab.future_iterations.list.3.title')}</strong> <span set:html={t('biolab.future_iterations.list.3.description')}></span></li>
                            <li><strong>{t('biolab.future_iterations.list.4.title')}</strong> <span set:html={t('biolab.future_iterations.list.4.description')}></span></li>
                        </ul>
                    </section>
                </div>

                <aside class="space-y-8 sticky top-24">
                    <div class="bg-zinc-900/50 backdrop-blur-sm p-6 rounded-2xl border border-white/20 shadow-xl shadow-orange-900/5">
                        <img
                            src={biolabEscapeScreenshot.src}
                            alt={t('biolab.aside.img_alt')}
                            class="w-full rounded-xl shadow-md mb-6"
                        />
                        <div class="flex flex-col gap-4">
                            <a
                                href="https://www.krr.cl/biolab-escape"
                                class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-600/20 transition-all hover:bg-blue-700 hover:-translate-y-0.5"
                            >
                                {t('biolab.aside.button1')}
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="ml-2 h-4 w-4">
                                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"></path>
                                </svg>
                            </a>
                            <a
                                href="#"
                                class="inline-flex items-center justify-center rounded-xl bg-zinc-800 px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:bg-zinc-700 hover:-translate-y-0.5"
                            >
                                {t('biolab.aside.button2')}
                            </a>
                        </div>
                    </div>

                    <div class="border-l-4 border-orange-200 pl-4 py-2">
                        <h3 class="font-semibold text-zinc-100 mb-2">{t('biolab.aside.team_title')}</h3>
                        <ul class="space-y-1">
                            {developers.map((dev) => (
                                <li class="text-zinc-300 text-sm">{dev}</li>
                            ))}
                        </ul>
                    </div>

                    <div class="pt-8 border-t border-gray-200/60">
                        <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">
                            {t('biolab.aside.tech_stack_title')}
                        </h2>
                        <div class="flex flex-wrap items-center gap-6">
                            {techStack.map((tech) => (
                                <div class="group relative">
                                    <img
                                        src={tech.src}
                                        alt={t(`biolab.aside.tech_${tech.name.toLowerCase().replace(/ /g, '_')}`)}
                                        class={`${tech.class} w-auto object-contain grayscale transition-all hover:grayscale-0`}
                                        loading="lazy"
                                    />
                                    <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-zinc-400 opacity-0 group-hover:opacity-100 transition-opacity">
                                        {t(`biolab.aside.tech_${tech.name.toLowerCase().replace(/ /g, '_')}`)}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>
                </aside>
            </div>
        </main>
</Layout>
