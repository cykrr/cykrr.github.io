---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import background from "@/assets/background.svg";
import Layout from "@/layouts/Layout.astro";
import NavBar from "@/components/NavBar.astro";

import logoUnity from "@/assets/badges/logo-unity.png";
import logoCsharp from "@/assets/badges/logo-csharp.png";
import logoAndroid from "@/assets/badges/android-logo.svg"; 

import planetariumPreview from "@/assets/previews/planetarium-vr.png";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const techStack = [
    { name: "Unity", src: logoUnity.src, class: "h-16" },
    { name: "C#", src: logoCsharp.src, class: "h-16" },
    { name: "Android", src: logoAndroid.src, class: "h-16" },
];

const developers = [
    "Oscar Rojas Gaete",
    "Sebastián Jeria López",
    "Benjamín Robles Arancibia",
    "Esteban Carrasco",
];

const perceptionData = [
    { dimension: "Inmersión enfocada", pre: 3.62, post: 4.39, color: "bg-blue-400" },
    { dimension: "Control", pre: 3.85, post: 4.37, color: "bg-indigo-400" },
    { dimension: "Valor / Utilidad", pre: 4.05, post: 4.44, color: "bg-purple-400" },
    { dimension: "Alegría / Diversión", pre: 3.96, post: 4.58, color: "bg-pink-400" },
    { dimension: "Facilidad de uso", pre: 3.80, post: 4.39, color: "bg-teal-400" },
];

// URLs de recursos - Reemplaza con tus links reales
const resources = {
    apk: "https://drive.google.com/file/d/15iG5YSNSe9tON2jddYGFWGzobvNgmfvF/view?usp=drive_link", // Link a la descarga del APK
    paper: "https://drive.google.com/file/d/1tiCZKmM5dPeR4aoe2jfIANety2N2PT6c/view",
    presentation: "https://drive.google.com/file/d/1bsfdamwXu0IlHVP8dhOZWGXoySFqibLE/view?usp=drive_link", // Link a tu Google Slides o Keynote
    video_demo: "https://www.youtube.com/embed/yPfOdVHTRV0"
};
---

<Layout>

        <main class="flex flex-col justify-center py-16 sm:py-24">
            <div class="mb-12">
                <h1 class="text-4xl font-extrabold tracking-tight text-zinc-100 sm:text-6xl text-balance mb-4">
                    {t('planetariumvr.title')}
                </h1>
                <p class="text-lg text-zinc-300 font-medium">
                    <strong>{t('planetariumvr.role')}</strong> Developer | <span class="text-gray-500 italic">{t('planetariumvr.team')} {developers.join(', ')}</span>
                </p>
                <!-- Add tags if applicable, for now, let's keep it minimal -->
                <!-- <div class="flex gap-2 mt-4">
                    {["VR", "EdTech", "Networking"].map(tag => (
                        <span class="px-3 py-1 bg-zinc-800 text-zinc-300 rounded-full text-sm font-semibold">{tag}</span>
                    ))}
                </div> -->
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
                <div class="lg:col-span-2 space-y-12 leading-relaxed text-zinc-300 text-pretty">
                    <!-- Case study content goes here, adapted from user's input -->
                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.overview.title')}</h2>
                        <p set:html={t('planetariumvr.overview.p1')}></p>
                        <p set:html={t('planetariumvr.overview.p2')}></p>
                        
                        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
                            <img src="/img/planetariumvr/planet-earth.png" alt={t('planetariumvr.overview.img1_alt')} class="rounded-xl border border-white/10 shadow-lg" />
                            <img src="/img/planetariumvr/planet-ring.png" alt={t('planetariumvr.overview.img2_alt')} class="rounded-xl border border-white/10 shadow-lg" />
                        </div>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.features.title')}</h2>
                        <h3 class="text-lg font-semibold text-zinc-100 mb-2">{t('planetariumvr.features.1.title')}</h3>
                        <p set:html={t('planetariumvr.features.1.description')}></p>

                        <h3 class="text-lg font-semibold text-zinc-100 mb-2">{t('planetariumvr.features.2.title')}</h3>
                        <p set:html={t('planetariumvr.features.2.description')}></p>

                        <div class="my-8">
                            <img src="/img/planetariumvr/point-to-grab.png" alt={t('planetariumvr.features.img3_alt')} class="w-full rounded-xl border border-white/10 shadow-lg" />
                            <p class="mt-2 text-sm text-zinc-500 italic text-center">{t('planetariumvr.features.img3_caption')}</p>
                        </div>

                        <h3 class="text-lg font-semibold text-zinc-100 mb-2">{t('planetariumvr.features.3.title')}</h3>
                        <p set:html={t('planetariumvr.features.3.description')}></p>

                        <div class="my-8">
                            <img src="/img/planetariumvr/physical-schema.png" alt={t('planetariumvr.features.img4_alt')} class="w-full rounded-xl bg-white/5 p-4 border border-white/10 shadow-lg" />
                            <p class="mt-2 text-sm text-zinc-500 italic text-center">{t('planetariumvr.features.img4_caption')}</p>
                        </div>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.testing.title')}</h2>
                        <p set:html={t('planetariumvr.testing.p1')}></p>
                        
                        <div class="my-10 bg-zinc-900/40 p-6 rounded-2xl border border-white/10 shadow-inner">
                            <h3 class="text-lg font-semibold text-zinc-100 mb-6 text-center">{t('planetariumvr.testing.questionnaire_title')}</h3>
                            <div class="space-y-6">
                                {perceptionData.map((item) => (
                                    <div class="space-y-2">
                                        <div class="flex justify-between text-sm font-medium text-zinc-300">
                                            <span>{t(`planetariumvr.testing.${item.dimension.toLowerCase().replace(/[^a-z0-9]/g, '')}`)}</span>
                                            <span class="text-zinc-500">
                                                <span class="text-zinc-400 font-bold">{item.post}</span> 
                                                <span class="text-xs ml-1">(+{ (item.post - item.pre).toFixed(2) })</span>
                                            </span>
                                        </div>
                                        <div class="relative h-4 w-full bg-zinc-800 rounded-full overflow-hidden">
                                            <!-- Pre-test bar -->
                                            <div 
                                                class="absolute top-0 left-0 h-full bg-zinc-600/50 transition-all duration-1000" 
                                                style={`width: ${(item.pre / 5) * 100}%`}
                                            ></div>
                                            <!-- Post-test bar -->
                                            <div 
                                                class={`absolute top-0 left-0 h-full ${item.color} opacity-80 transition-all duration-1000 shadow-[0_0_15px_rgba(255,255,255,0.1)]`} 
                                                style={`width: ${(item.post / 5) * 100}%`}
                                            ></div>
                                        </div>
                                        <div class="flex justify-between text-[10px] text-zinc-500 px-1">
                                            <span>{t('planetariumvr.testing.pre_test')}: {item.pre}</span>
                                            <span>{t('planetariumvr.testing.post_test')}: {item.post}</span>
                                        </div>
                                    </div>
                                ))}
                            </div>
                            <div class="mt-6 flex justify-center gap-6 text-xs text-zinc-400">
                                <div class="flex items-center gap-2">
                                    <div class="w-3 h-3 bg-zinc-600/50 rounded-sm"></div>
                                    <span>{t('planetariumvr.testing.pre_test')}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <div class="w-3 h-3 bg-blue-400 rounded-sm"></div>
                                    <span>{t('planetariumvr.testing.post_test')}</span>
                                </div>
                            </div>
                        </div>

                        <p set:html={t('planetariumvr.testing.p2')}></p>
                        <ul class="list-disc ml-6 mt-4 space-y-2">
                            <li><strong>{t('planetariumvr.testing.list.immersion')}</strong> +0.77 (3.62 → 4.39)</li>
                            <li><strong>{t('planetariumvr.testing.list.joy')}</strong> +0.62 (3.96 → 4.58)</li>
                            <li><strong>{t('planetariumvr.testing.list.ease_of_use')}</strong> +0.60 (3.80 → 4.39)</li>
                            <li><strong>{t('planetariumvr.testing.list.control')}</strong> +0.52 (3.85 → 4.37)</li>
                            <li><strong>{t('planetariumvr.testing.list.value')}</strong> +0.40 (4.05 → 4.44)</li>
                        </ul>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
                            <img src="/img/planetariumvr/user-testing-1.jpeg" alt={t('planetariumvr.testing.img5_alt')} class="rounded-xl border border-white/10 shadow-lg" />
                            <img src="/img/planetariumvr/user-testing-2.jpeg" alt={t('planetariumvr.testing.img6_alt')} class="rounded-xl border border-white/10 shadow-lg" />
                        </div>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.feedback.title')}</h2>
                        <p set:html={t('planetariumvr.feedback.p1')}></p>
                        <ul class="list-disc ml-6 mt-4 space-y-2">
                            <li><em set:html={`"${t('planetariumvr.feedback.quote1')}"`}></em></li>
                            <li><em set:html={`"${t('planetariumvr.feedback.quote2')}"`}></em></li>
                            <li><em set:html={`"${t('planetariumvr.feedback.quote3')}"`}></em></li>
                        </ul>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.challenges.title')}</h2>
                        <p set:html={t('planetariumvr.challenges.p1')}></p>
                        <ol class="list-decimal ml-6 mt-4 space-y-4">
                            <li><strong>{t('planetariumvr.challenges.1.title')}</strong> <span set:html={t('planetariumvr.challenges.1.description')}></span></li>
                            <li><strong>{t('planetariumvr.challenges.2.title')}</strong> <span set:html={t('planetariumvr.challenges.2.description')}></span></li>
                        </ol>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.roadmap.title')}</h2>
                        <p set:html={t('planetariumvr.roadmap.p1')}></p>
                        <ul class="list-disc ml-6 mt-4 space-y-2">
                            <li><strong>{t('planetariumvr.roadmap.1.title')}</strong> <span set:html={t('planetariumvr.roadmap.1.description')}></span></li>
                            <li><strong>{t('planetariumvr.roadmap.2.title')}</strong> <span set:html={t('planetariumvr.roadmap.2.description')}></span></li>
                            <li><strong>{t('planetariumvr.roadmap.3.title')}</strong> <span set:html={t('planetariumvr.roadmap.3.description')}></span></li>
                        </ul>
                    </section>

                    <section>
                        <h2 class="text-2xl font-bold text-zinc-100 mb-4">{t('planetariumvr.takeaways.title')}</h2>
                        <p set:html={t('planetariumvr.takeaways.p1')}></p>
                    </section>
                </div>

                <aside class="space-y-8 sticky top-24">
                    <div class="bg-zinc-900/50 backdrop-blur-sm p-6 rounded-2xl border border-white/20 shadow-xl shadow-blue-900/5">
                        <img
                            src={planetariumPreview.src}
                            alt={t('planetariumvr.aside.img_alt')}
                            class="w-full rounded-xl shadow-md mb-6"
                        />
                        <div class="flex flex-col gap-4">
                            <!-- Using video_demo from frontmatter -->
                            <a
                                href={resources.video_demo}
                                class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-600/20 transition-all hover:bg-blue-700 hover:-translate-y-0.5"
                            >
                                {t('planetariumvr.aside.button1')}
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="ml-2 h-4 w-4">
                                    <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.841z" />
                                </svg>
                            </a>
                            <!-- Using the GitHub link from the case study -->
                            <a
                                href="https://github.com/cykrr/planetariumvr"
                                class="inline-flex items-center justify-center rounded-xl bg-zinc-800 px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:bg-zinc-700 hover:-translate-y-0.5"
                            >
                                {t('planetariumvr.aside.button2')}
                                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="ml-2 h-4 w-4">
                                    <path fill-rule="evenodd" d="M12.5 5A2.5 2.5 0 0115 7.5v5A2.5 2.5 0 0112.5 15h-8A2.5 2.5 0 012 12.5v-5A2.5 2.5 0 014.5 5h8zM10 8a.5.5 0 00-1 0v4a.5.5 0 001 0V8zm-3 0a.5.5 0 00-1 0v4a.5.5 0 001 0V8zm6 0a.5.5 0 00-1 0v4a.5.5 0 001 0V8z" clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <div class="border-l-4 border-blue-200 pl-4 py-2">
                        <h3 class="font-semibold text-zinc-100 mb-2">{t('planetariumvr.aside.team_title')}</h3>
                        <ul class="space-y-1">
                            {developers.map((dev) => (
                                <li class="text-zinc-300 text-sm">{dev}</li>
                            ))}
                        </ul>
                    </div>

                    <div class="pt-8 border-t border-gray-200/60">
                        <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">
                            {t('planetariumvr.aside.tech_stack_title')}
                        </h2>
                        <div class="mt-6 flex flex-wrap items-center gap-6">
                            {techStack.map((tech) => (
                                <div class="group relative">
                                    <img
                                        src={tech.src}
                                        alt={t(`planetariumvr.aside.tech_${tech.name.toLowerCase()}`)}
                                        class={`${tech.class} w-auto object-contain grayscale transition-all hover:grayscale-0`}
                                        loading="lazy"
                                    />
                                    <span class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-bold text-zinc-400 opacity-0 group-hover:opacity-100 transition-opacity">
                                        {t(`planetariumvr.aside.tech_${tech.name.toLowerCase()}`)}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </div>
                </aside>
            </div>

            <section class="mt-16 pt-8 border-t border-white/10">
                <h2 class="text-2xl font-bold text-zinc-100 mb-6">{t('planetariumvr.resources.title')}</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <a href={resources.apk} target="_blank" class="group p-6 bg-zinc-900/40 backdrop-blur-sm border border-white/10 rounded-2xl hover:border-blue-400 hover:bg-zinc-800 transition-all">
                        <div class="text-blue-400 mb-4 group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <h3 class="font-bold text-zinc-100 text-lg">{t('planetariumvr.resources.apk.title')}</h3>
                        <p class="text-sm text-zinc-400 mt-2">{t('planetariumvr.resources.apk.description')}</p>
                    </a>
                    <a href={resources.paper} target="_blank" class="group p-6 bg-zinc-900/40 backdrop-blur-sm border border-white/10 rounded-2xl hover:border-blue-400 hover:bg-zinc-800 transition-all">
                        <div class="text-blue-400 mb-4 group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                        </div>
                        <h3 class="font-bold text-zinc-100 text-lg">{t('planetariumvr.resources.paper.title')}</h3>
                        <p class="text-sm text-zinc-400 mt-2">{t('planetariumvr.resources.paper.description')}</p>
                    </a>
                    <a href={resources.presentation} target="_blank" class="group p-6 bg-zinc-900/40 backdrop-blur-sm border border-white/10 rounded-2xl hover:border-blue-400 hover:bg-zinc-800 transition-all">
                        <div class="text-blue-400 mb-4 group-hover:scale-110 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
                            </svg>
                        </div>
                        <h3 class="font-bold text-zinc-100 text-lg">{t('planetariumvr.resources.presentation.title')}</h3>
                        <p class="text-sm text-zinc-400 mt-2">{t('planetariumvr.resources.presentation.description')}</p>
                    </a>
                </div>
            </section>
            <!-- Remove the prose-invert class from main, as we are manually styling. Also removed the tips p tag -->
        </main>
</Layout>
