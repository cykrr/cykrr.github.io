---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

// src/components/features/portfolio.astro

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="mb-8">
  <h2 class="text-zinc-100 text-xl font-bold border-b border-zinc-700 pb-1 mb-4 mt-8">
    {t('portfolio.infra.title')}
  </h2>
  <p class="mb-4 text-zinc-300 leading-relaxed" set:html={t('portfolio.infra.description')}>
  </p>
  
  <div class="overflow-x-auto">
    <table class="w-full border-collapse mt-4 text-sm sm:text-base text-zinc-300">
      <thead>
        <tr>
          <th class="border border-zinc-700 p-2.5 text-left bg-zinc-800/80 text-zinc-100 font-semibold">{t('portfolio.table.service')}</th>
          <th class="border border-zinc-700 p-2.5 text-left bg-zinc-800/80 text-zinc-100 font-semibold">{t('portfolio.table.url')}</th>
          <th class="border border-zinc-700 p-2.5 text-left bg-zinc-800/80 text-zinc-100 font-semibold">{t('portfolio.table.notes')}</th>
        </tr>
      </thead>
      <tbody class="align-top">
        <tr class="hover:bg-zinc-800/30 transition-colors">
          <td class="border border-zinc-700 p-2.5 whitespace-nowrap">Voz-CL</td>
          <td class="border border-zinc-700 p-2.5"><a href="https://voz-cl.krr.cl">voz-cl.krr.cl</a></td>
          <td class="border border-zinc-700 p-2.5" set:html={t('portfolio.table.vozcl.notes')}></td>
        </tr>
        <tr class="hover:bg-zinc-800/30 transition-colors">
          <td class="border border-zinc-700 p-2.5 whitespace-nowrap">Biolab Escape</td>
          <td class="border border-zinc-700 p-2.5"><a href="https://krr.cl/biolab-escape">krr.cl/biolab-escape</a></td>
          <td class="border border-zinc-700 p-2.5" set:html={t('portfolio.table.biolab.notes')}></td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<section class="mb-8">
  <h2 id="projects" class="text-zinc-100 text-xl font-bold border-b border-zinc-700 pb-1 mb-4 mt-8">
    {t('portfolio.software.title')}
  </h2>
  <p class="mb-4 text-zinc-300 leading-relaxed" set:html={t('portfolio.software.description')}>
  </p>
  <ul class="list-square flex flex-col gap-5 text-zinc-300 leading-relaxed marker:text-zinc-500 pl-4">
    <li><strong class="text-zinc-100 font-semibold">{t('portfolio.software.chilean_asr.title')}</strong> <span set:html={t('portfolio.software.chilean_asr.description')}></span></li>
    <li><strong class="text-zinc-100 font-semibold">{t('portfolio.software.cc_systems.title')}</strong> <span set:html={t('portfolio.software.cc_systems.description')}></span></li>
    <li><strong class="text-zinc-100 font-semibold">{t('portfolio.software.freelance_saas.title')}</strong> <span set:html={t('portfolio.software.freelance_saas.description')}></span></li>
    <li><strong class="text-zinc-100 font-semibold">{t('portfolio.software.planetariumvr.title')}</strong>
      <span set:html={t('portfolio.software.planetariumvr.description')}></span>
      <a href="/portfolio/planetarium-vr">{t('portfolio.software.planetariumvr.view_project')}</a>
      <a href="https://github.com/cykrr/planetariumvr">{t('portfolio.software.planetariumvr.github')}</a></li>

    <li>
      <strong class="text-zinc-100 font-semibold">{t('portfolio.software.floreria_coral.title')}</strong>
      <span set:html={t('portfolio.software.floreria_coral.description')}></span>
    </li>

    <li><strong class="text-zinc-100 font-semibold">{t('portfolio.software.biolab_escape.title')}</strong> <span set:html={t('portfolio.software.biolab_escape.description')}></span> <a href="/portfolio/biolab-escape">{t('portfolio.software.biolab_escape.view_project')}</a></li>
  </ul>
</section>

<section class="bg-yellow-900/20 border border-yellow-700/50 p-4 my-8 text-yellow-200">
  <strong class="text-yellow-500 font-bold tracking-wide">{t('portfolio.warning.title')}</strong> <span set:html={t('portfolio.warning.description')}></span> <a href="https://status.krr.cl/status/krr-cl">{t('portfolio.warning.status')}</a>.
</section>

<p class="text-zinc-500 text-sm italic">
  {t('portfolio.footer.text')}
</p>
