---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { languages, ui, defaultLang } from "../i18n/ui";

const { pathname } = Astro.url;
const isHome = pathname === "/" || pathname === "/index.html";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<nav class="mb-12 mt-4">
  <div>
    <div class="flex items-baseline justify-between border-b border-zinc-700 pb-1 mb-2">
      <h1 class="text-zinc-100 text-2xl font-bold">
        <a href={lang === defaultLang ? "/" : `/${lang}/`} class="hover:text-pink-400 no-underline transition-colors">{t('site.title')}</a>
      </h1>
      <div class="flex gap-4 text-sm font-bold uppercase tracking-widest">
          <a href={lang === defaultLang ? "/zen" : `/${lang}/zen`} class="text-zinc-400 hover:text-pink-400 no-underline transition-colors">{t('nav.zen')}</a>
          <a href="https://status.krr.cl/status/krr-cl" class="text-zinc-400 hover:text-pink-400 no-underline transition-colors">{t('nav.status')}</a>
          <a href="#projects" class="text-zinc-400 hover:text-pink-400 no-underline transition-colors">{t('nav.projects')}</a>
      </div>    </div>
    <!-- Language selector row will go here -->
    <div class="flex justify-end text-sm mb-2">
      {Object.entries(languages).map(([locale, name]) => (
        <a
          href={(() => {
            let targetPath = pathname.replace(`/${lang}`, '');
            if (targetPath === '') targetPath = '/';
            return locale === defaultLang ? targetPath : `/${locale}${targetPath === '/' ? '' : targetPath}`;
          })()}
          class={`ml-2 ${locale === lang ? 'font-bold text-pink-400' : 'text-zinc-400 hover:text-pink-400'} no-underline transition-colors`}
        >
          {name}
        </a>
      ))}
    </div>
  </div>
  {isHome && (
    <p class="text-zinc-400 italic text-sm sm:text-base">
      {t('navbar.motiv')}
    </p>
  )}
</nav>
